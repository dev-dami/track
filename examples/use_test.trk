@use("std/io")
@use("math/vec")

fn test_example1() -> void {
    io::print(111);
}

@use("std/io::{print, read}")
@use("math/vec::{add, sub}")

fn test_example2() -> void {
    print(222);
    let a = add(10, 20);
    print(a);
}

@use("std/io") as console
@use("math/vec::{add}") as sum

fn test_example3() -> void {
    console::print(333);
    let b = sum(30, 40);
    print(b);
}

fn main() -> void {
    test_example1();
    test_example2();
    test_example3();
}
